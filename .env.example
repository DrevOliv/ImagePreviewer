.env.example# Copy this file to `.env` in the project root and edit the values.
# Any variable you leave unset here falls back to the default.
# Real environment variables always take precedence over this file.

# ─── Required ──────────────────────────────────────────────
APP_PASSWORD=changeme
# Generate a long random string:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=please-generate-a-long-random-string

# ─── Paths (override defaults) ─────────────────────────────
# Folders you want to browse (Docker usually mounts under /data).
# For local dev, point this somewhere under your home directory.
# DATA_ROOT=/data

# Where generated previews are cached (WebP files, keyed by mtime).
# CACHE_ROOT=/cache

# Where app state lives (likes.json, future DB files).
# STATE_ROOT=/state

# ─── Tuning (optional) ─────────────────────────────────────
# THUMBNAIL_SIZE=400
# FULL_PREVIEW_SIZE=2500
# SESSION_MAX_AGE=2592000    # 30 days, in seconds

# Max on-disk preview cache size (MB). When exceeded, the oldest-used files
# are deleted until the cache is down to 90% of this. Set 0 to disable eviction.
# CACHE_MAX_MB=2048
# How often (seconds) the background sweeper checks the cache size.
# CACHE_SWEEP_INTERVAL=300
